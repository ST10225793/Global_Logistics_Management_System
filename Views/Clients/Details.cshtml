@model Global_Logistics_Management_System.Models.Client

@{
    ViewData["Title"] = "Client Details";
}

<div class="form-card col-md-8 mx-auto mt-4 text-center">
    <div class="mb-4">
        <i class="bi bi-eye-fill" style="font-size: 3rem; color: #f06292;"></i>
        <h1 class="form-title">@Model.Name</h1>
        <p class="form-subtitle">Global Partnership Profile Information</p>
    </div>

    <hr style="border-top: 2px dashed #fce4ec;" />

        <div class="col-md-6 mb-3">
            <div class="p-3 rounded-4 shadow-sm" style="background-color: #fffafb; border-left: 5px solid #f06292;">
                <h6 class="fw-bold" style="color: #880e4f;">
                    <i class="bi bi-envelope-heart me-2"></i>Email Address
                </h6>
                <p class="mb-0">@Html.DisplayFor(model => model.Email)</p>
            </div>
        </div>

        <div class="col-12 mb-4">
            <div class="p-4 rounded-4" style="background-color: #fff0f3; border: 1px solid #fce4ec;">
                <h6 class="fw-bold" style="color: #880e4f;">
                    <i class="bi bi-shield-heart-fill me-2"></i>Account Overview
                </h6>
                <p class="mb-0 mt-2" style="line-height: 1.6; color: #6c757d;">
                    This account holds authorized logistical permissions to link standard framework agreements and spawn global delivery pipeline request nodes under the registered legal entity title of <strong>@Model.Name</strong>.
                </p>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-center gap-3 mt-2">
        <a asp-action="Edit" asp-route-id="@Model?.ClientId" class="btn btn-pink px-4">
            <i class="bi bi-pencil-heart"></i> Edit Profile
        </a>
        <a asp-action="Index" class="btn-back">
            <i class="bi bi-arrow-left-circle"></i> Back to Directory
        </a>
    </div>
</div>

<style>
    /* Retaining exact card elevation metrics from template styles */
    .shadow-sm {
        transition: transform 0.2s ease-in-out;
    }

        .shadow-sm:hover {
            transform: translateY(-3px);
        }
</style>