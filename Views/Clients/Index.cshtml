@model IEnumerable<Global_Logistics_Management_System.Models.Client>

@{
    ViewData["Title"] = "Clients Directory";
}

@* Optional block for contextual layout alerts if thrown from the controller *@
@if (TempData["Error"] != null)
{
    <div class="alert alert-pink alert-dismissible fade show" role="alert">
        <strong>Hold on! 🎀</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="form-card mt-4">
    <div class="text-center mb-4">
        <i class="bi bi-people-fill" style="font-size: 3rem; color: #f06292;"></i>
        <h1 class="form-title">Global Client Profiles</h1>
        <p class="form-subtitle">Manage all your partnership profiles in one place! ✨</p>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 style="color: #880e4f;">Registered Clients</h4>
        <a asp-action="Create" class="btn btn-pink">
            <i class="bi bi-plus-circle"></i> Create New Client
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover">
            <thead style="background-color: #fffafb;">
                <tr style="color: #880e4f;">
                    <th>@Html.DisplayNameFor(model => model.Name)</th>
                    <th>@Html.DisplayNameFor(model => model.Email)</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold" style="color: #f06292;">
                            @Html.DisplayFor(modelItem => item.Name)
                        </td>
                        <td>
                            <i class="bi bi-envelope-heart me-1"></i>
                            @Html.DisplayFor(modelItem => item.Email)
                        </td>
                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <a asp-action="Edit" asp-route-id="@item.ClientId" class="btn btn-sm btn-outline-pink">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Details" asp-route-id="@item.ClientId" class="btn btn-sm btn-outline-secondary ms-1">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.ClientId" class="btn btn-sm btn-outline-danger ms-1">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>