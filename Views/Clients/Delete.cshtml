@model Global_Logistics_Management_System.Models.Client

@{
    ViewData["Title"] = "Delete Client Profile";
}

<div class="form-card col-md-8 mx-auto mt-4 text-center border-danger-subtle">
    <div class="mb-4">
        <i class="bi bi-patch-exclamation" style="font-size: 3rem; color: #dc3545;"></i>
        <h1 class="form-title" style="color: #dc3545;">Terminate Partnership?</h1>
        <p class="form-subtitle">Are you sure you want to permanently delete the profile for <strong>@Model.Name</strong>?</p>
    </div>

    <div class="p-4 rounded-4 mb-4" style="background-color: #fff5f5; border: 1px solid #f8d7da;">
        <div class="row align-items-center">
            <div class="col-md-2 text-center">
                <i class="bi bi-building-dash text-pink-theme" style="font-size: 2.5rem;"></i>
            </div>
            <div class="col-md-10 text-start">
                <h5 class="fw-bold mb-1 text-pink-theme">@Model.Name</h5>

                <div class="mt-2 small text-dark fw-medium">
                    <p class="mb-0">
                        <i class="bi bi-envelope-heart me-2 text-secondary"></i>
                        Account Email: <span class="text-muted">@Model.Email</span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="alert alert-warning rounded-4 border-0 mb-4" style="background-color: #fff3cd; color: #856404; font-size: 0.9rem; text-align: left;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        <strong>Warning:</strong> Cascading constraint alert! Removing this account profile will isolate or remove any historic Service Level Agreements (SLAs) and tracking ledgers linked to this client entity.
    </div>

    <form asp-action="Delete">
        <input type="hidden" asp-for="ClientId" />

        <div class="d-flex justify-content-center gap-3">
            <button type="submit" class="btn btn-danger px-4 rounded-pill fw-bold">
                <i class="bi bi-trash3-fill me-2"></i>Yes, Delete Client
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill fw-bold">
                No, Keep the Profile!
            </a>
        </div>
    </form>
</div>

<style>
    /* Injected exact EventEase page style rules overrides */
    .border-danger-subtle {
        border: 2px solid #f8d7da !important;
    }

    .btn-danger {
        background-color: #d32f2f;
        border: none;
        transition: transform 0.2s;
    }

        .btn-danger:hover {
            background-color: #b71c1c;
            transform: scale(1.05);
        }
</style>