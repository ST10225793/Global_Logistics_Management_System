@model Global_Logistics_Management_System.Models.Client

@{
    ViewData["Title"] = "Create Client";
}

<div class="form-card text-center col-md-8 mx-auto mt-4">
    <i class="bi bi-person-plus-fill" style="font-size: 3rem; color: #f06292;"></i>

    <h1 class="form-title">Create Client Profile</h1>
    <p class="form-subtitle">Let's build another beautiful partnership! </p>

    <div class="row text-start justify-content-center">
        <div class="col-md-8">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="Name" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <input asp-for="Name" class="form-control" placeholder="E.g., Princess Logistics Ltd" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="Email" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <input asp-for="Email" class="form-control" placeholder="client@magical-shipping.com" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-group text-center">
                    <input type="submit" value="Create Client ✨" class="btn btn-pink w-100" />
                </div>
            </form>
        </div>
    </div>

    <div class="mt-4 text-center">
        <a asp-action="Index" class="btn-back"><i class="bi bi-arrow-left-circle"></i> Back to the Schedule</a>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}