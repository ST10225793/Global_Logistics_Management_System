@model Global_Logistics_Management_System.Models.Contract

@{
    ViewData["Title"] = "Create Contract";
}

<div class="form-card text-center col-md-8 mx-auto mt-4">
    <i class="bi bi-file-earmark-plus-fill" style="font-size: 3rem; color: #f06292;"></i>
    <h1 class="form-title">Create Contract Arrangement</h1>
    <p class="form-subtitle">Let's secure another beautiful baseline framework agreement! </p>

    <div class="row text-start justify-content-center">
        <div class="col-md-8">
            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="ContractName" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <input asp-for="ContractName" class="form-control" placeholder="E.g., Q2 Standard Freight Clause" />
                    <span asp-validation-for="ContractName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Description" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <input asp-for="Description" class="form-control" placeholder="Provide a brief contract overview..." />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Status" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <select asp-for="Status" class="form-control" asp-items="Html.GetEnumSelectList<Global_Logistics_Management_System.Models.ContractStatus>()"></select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="ServiceLevel" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <input asp-for="ServiceLevel" class="form-control" placeholder="E.g., Gold, Premium Shipping, 48hr SLA" />
                    <span asp-validation-for="ServiceLevel" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="StartDate" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <input asp-for="StartDate" class="form-control" type="date" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="EndDate" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <input asp-for="EndDate" class="form-control" type="date" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="CostUSD" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <input asp-for="CostUSD" class="form-control" type="number" step="0.01" placeholder="0.00" />
                    <span asp-validation-for="CostUSD" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold" style="color: #880e4f;">Upload Signed Contract (PDF)</label>
                    <input type="file" name="pdfFile" class="form-control" accept=".pdf" />
                </div>

                <div class="form-group mb-4">
                    <label asp-for="ClientId" class="control-label fw-bold" style="color: #880e4f;">Client Name</label>
                    <select asp-for="ClientId" class="form-control" asp-items="ViewBag.ClientId"></select>
                </div>

                <div class="form-group text-center">
                    <input type="submit" value="Create Contract ✨" class="btn btn-pink w-100" />
                </div>
            </form>
        </div>
    </div>

    <div class="mt-4 text-center">
        <a asp-action="Index" class="btn-back"><i class="bi bi-arrow-left-circle"></i> Back to the Schedule</a>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}