@model Global_Logistics_Management_System.Models.Contract

@{
    ViewData["Title"] = "Edit Contract Arrangement";
}

<div class="form-card text-center col-md-8 mx-auto mt-4">
    <i class="bi bi-pencil-square" style="font-size: 3rem; color: #f06292;"></i>
    <h1 class="form-title">Edit Contract Details</h1>
    <p class="form-subtitle">Polishing agreement clauses for <strong>@Model.ContractName</strong> 🎀</p>

    <div class="row text-start justify-content-center">
        <div class="col-md-8">
            <form asp-action="Edit" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="ContractId" />
                <input type="hidden" asp-for="SignedAgreementPath" />

                <div class="form-group mb-3">
                    <label asp-for="ContractName" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <input asp-for="ContractName" class="form-control" />
                    <span asp-validation-for="ContractName" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Description" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <input asp-for="Description" class="form-control" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Status" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<Global_Logistics_Management_System.Models.ContractStatus>()"></select>
                    <span asp-validation-for="Status" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="ServiceLevel" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <input asp-for="ServiceLevel" class="form-control" />
                    <span asp-validation-for="ServiceLevel" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="StartDate" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <input asp-for="StartDate" class="form-control" type="date" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="EndDate" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <input asp-for="EndDate" class="form-control" type="date" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="CostUSD" class="control-label fw-bold" style="color: #880e4f;">Base Allocation (USD $)</label>
                    <input asp-for="CostUSD" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="CostUSD" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label class="control-label fw-bold" style="color: #880e4f;">Replace Signed Contract File</label>
                    <input type="file" name="pdfFile" class="form-control" accept=".pdf" />
                    @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
                    {
                        <small class="text-success d-block mt-1"><i class="bi bi-file-earmark-check-fill"></i> Current file: Saved on server</small>
                    }
                    else
                    {
                        <small class="text-muted d-block mt-1">Leave blank to keep current</small>
                    }
                </div>

                <div class="form-group mb-4">
                    <label asp-for="ClientId" class="control-label fw-bold" style="color: #880e4f;">Client Name</label>
                    <select asp-for="ClientId" class="form-select" asp-items="ViewBag.ClientId"></select>
                    <span asp-validation-for="ClientId" class="text-danger"></span>
                </div>

                <div class="form-group text-center">
                    <button type="submit" class="btn btn-pink w-100">
                        <i class="bi bi-check2-heart"></i> Update Contract
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="mt-4 text-center">
        <a asp-action="Index" class="btn-back">
            <i class="bi bi-arrow-left-circle"></i> Back to Tracking Registry
        </a>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}