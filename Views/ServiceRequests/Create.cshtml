@model Global_Logistics_Management_System.Models.ServiceRequest

@{
    ViewData["Title"] = "Create Service Request";
}

<h1>Create</h1>

<h4>Service Request</h4>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="JobDescription" class="control-label"></label>
                <textarea asp-for="JobDescription" class="form-control" rows="3"></textarea>
                <span asp-validation-for="JobDescription" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="ContractId" class="control-label">Link to Contract</label>
                <select asp-for="ContractId" class="form-control" asp-items="ViewBag.ContractId">
                    <option value="">-- Select Contract --</option>
                </select>
                <span asp-validation-for="ContractId" class="text-danger"></span>
            </div>

            <div class="card p-3 bg-light mb-3">
                <h5 class="text-secondary">Currency Converter (Live API)</h5>

                <div class="form-group mb-2">
                    <label class="control-label fw-bold">Amount (USD $):</label>
                    <input type="number" id="inputUSD" class="form-control" placeholder="Type dollar amount..." step="0.01" />
                </div>

                <div class="form-group mb-2">
                    <label asp-for="Cost" class="control-label fw-bold">Calculated Cost (ZAR R):</label>
                    <input asp-for="Cost" id="inputZAR" class="form-control text-success fw-bold" readonly placeholder="R 0.00" />
                    <span asp-validation-for="Cost" class="text-danger"></span>
                </div>

                <small id="rateIndicator" class="text-muted">Fetching live conversion metrics via HttpClient...</small>
            </div>

            <div class="form-group">
                <input type="submit" value="Submit Request" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary ms-2">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let currentExchangeRate = 18.50; // Standard layout safe default
            const usdInput = document.getElementById("inputUSD");
            const zarInput = document.getElementById("inputZAR");
            const indicator = document.getElementById("rateIndicator");

            // 1. Instantly ping our backend endpoint when the page loads to get the live HttpClient rate
            fetch('/ServiceRequests/GetLiveExchangeRate')
                .then(response => response.json())
                .then(data => {
                    if (data && data.rate) {
                        currentExchangeRate = data.rate;
                        indicator.innerText = "Live Rate: 1 USD = R " + currentExchangeRate.toFixed(2) + " (Fetched via HttpClient)";
                    }
                })
                .catch(error => {
                    console.error("Error loading exchange rate:", error);
                    indicator.innerText = "Using baseline rate connection: 1 USD = R 18.50";
                });

            // 2. Add an event listener to listen whenever the user types into the USD field
            usdInput.addEventListener("input", function () {
                const usdValue = parseFloat(usdInput.value);

                if (!isNaN(usdValue) && usdValue > 0) {
                    // Perform the currency conversion math instantly on the fly
                    const totalZar = usdValue * currentExchangeRate;
                    zarInput.value = totalZar.toFixed(2);
                } else {
                    zarInput.value = "";
                }
            });
        });
    </script>
}