@model Global_Logistics_Management_System.Models.ServiceRequest

@{
    ViewData["Title"] = "Create Magical Service Request";
}

<div class="form-card text-center col-md-8 mx-auto mt-4">
    <i class="bi bi-stars" style="font-size: 3rem; color: #f06292;"></i>
    <h1 class="form-title">Create Service Request</h1>
    <p class="form-subtitle">Let's schedule a] beautiful operational milestone! </p>

    <div class="row text-start justify-content-center">
        <div class="col-md-8">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="JobDescription" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <textarea asp-for="JobDescription" class="form-control" rows="3" placeholder="Describe the deployment magic..."></textarea>
                    <span asp-validation-for="JobDescription" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="ContractId" class="control-label fw-bold" style="color: #880e4f;">Link Framework Contract</label>
                    <select asp-for="ContractId" class="form-control" asp-items="ViewBag.ContractId">
                        <option value="">-- Select Target Contract Alignment --</option>
                    </select>
                    <span asp-validation-for="ContractId" class="text-danger"></span>
                </div>

                <div class="card p-3 bg-light mb-4 border-pink border">
                    <h5 class="fw-bold text-pink-theme">Currency Converter (Live API)</h5>

                    <div class="form-group mb-2">
                        <label class="control-label fw-bold text-muted">Amount (USD $):</label>
                        <input type="number" id="inputUSD" class="form-control" placeholder="Type baseline dollar cost fractions..." step="0.01" />
                    </div>

                    <div class="form-group mb-2">
                        <label asp-for="Cost" class="control-label fw-bold text-muted">Calculated Evaluation (ZAR R):</label>
                        <input asp-for="Cost" id="inputZAR" class="form-control text-success fw-bold" readonly placeholder="R 0.00" />
                        <span asp-validation-for="Cost" class="text-danger"></span>
                    </div>

                    <small id="rateIndicator" class="text-muted italic">Pinging real-time exchange metrics via HttpClient...</small>
                </div>

                <div class="form-group text-center">
                    <input type="submit" value="Dispatch Request ✨" class="btn btn-pink w-100" />
                </div>
            </form>
        </div>
    </div>

    <div class="mt-4 text-center">
        <a asp-action="Index" class="btn-back"><i class="bi bi-arrow-left-circle"></i> Back to the Operational Schedule</a>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let currentExchangeRate = 18.50; // Standard layout safe default
            const usdInput = document.getElementById("inputUSD");
            const zarInput = document.getElementById("inputZAR");
            const indicator = document.getElementById("rateIndicator");

            // 1. Instantly ping our backend endpoint when the page loads to get the live HttpClient rate
            fetch('/ServiceRequests/GetLiveExchangeRate')
                .then(response => response.json())
                .then(data => {
                    if (data && data.rate) {
                        currentExchangeRate = data.rate;
                        indicator.innerText = "Live Rate: 1 USD = R " + currentExchangeRate.toFixed(2) + " (Fetched via HttpClient)";
                    }
                })
                .catch(error => {
                    console.error("Error loading exchange rate:", error);
                    indicator.innerText = "Using baseline rate connection: 1 USD = R 18.50";
                });

            // 2. Add an event listener to listen whenever the user types into the USD field
            usdInput.addEventListener("input", function () {
                const usdValue = parseFloat(usdInput.value);

                if (!isNaN(usdValue) && usdValue > 0) {
                    // Perform the currency conversion math instantly on the fly
                    const totalZar = usdValue * currentExchangeRate;
                    zarInput.value = totalZar.toFixed(2);
                } else {
                    zarInput.value = "";
                }
            });
        });
    </script>
}