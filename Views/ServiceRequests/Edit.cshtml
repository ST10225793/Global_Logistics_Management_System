@model Global_Logistics_Management_System.Models.ServiceRequest

@{
    ViewData["Title"] = "Edit Service Request";
}

<div class="form-card text-center col-md-8 mx-auto mt-4">
    <i class="bi bi-pencil-square" style="font-size: 3rem; color: #f06292;"></i>
    <h1 class="form-title">Edit Service Request Details</h1>
    <p class="form-subtitle">Polishing operational parameters for <strong>Order #@Model.RequestId</strong> 🎀</p>

    <div class="row text-start justify-content-center">
        <div class="col-md-8">
            <form asp-action="Edit">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="RequestId" />
                <input type="hidden" asp-for="RequestDate" />
                <input type="hidden" asp-for="Cost" />

                <div class="form-group mb-3">
                    <label asp-for="JobDescription" class="control-label fw-bold" style="color: #880e4f;"></label>
                    <textarea asp-for="JobDescription" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="JobDescription" class="text-danger"></span>
                </div>

                <div class="form-group mb-4">
                    <label asp-for="ContractId" class="control-label fw-bold" style="color: #880e4f;">Linked Framework Contract</label>
                    <select asp-for="ContractId" class="form-select" asp-items="ViewBag.ContractId"></select>
                    <span asp-validation-for="ContractId" class="text-danger"></span>
                </div>

                <div class="p-3 bg-light rounded mb-4 text-center border-pink border">
                    <span class="text-muted small d-block">Saved ZAR Conversion Value (API-driven)</span>
                    <strong class="fs-4 text-success">R @Model.Cost.ToString("N2")</strong>
                </div>

                <div class="form-group text-center">
                    <button type="submit" class="btn btn-pink w-100">
                        <i class="bi bi-check2-heart"></i> Update Request
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="mt-4 text-center">
        <a asp-action="Index" class="btn-back">
            <i class="bi bi-arrow-left-circle"></i> Back to Operational Schedule
        </a>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}