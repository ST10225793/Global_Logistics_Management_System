@model IEnumerable<Global_Logistics_Management_System.Models.Contract>

@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .hello-kitty-float {
        max-width: 120px;
        margin: 0 auto;
        animation: float 3s ease-in-out infinite;
    }

    @@keyframes float {
        0% {
            transform: translateY(0px);
        }

        50% {
            transform: translateY(-10px);
        }

        100% {
            transform: translateY(0px);
        }
    }

    .stat-card {
        border-radius: 15px;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 20px rgba(255, 105, 180, 0.25) !important;
        }

    .card-icon {
        font-size: 2.5rem;
        color: #f06292; /* Matched to exact EventEase pink icon hex code */
    }

    .btn-pink {
        background-color: #f06292 !important; /* Matched to exact EventEase primary pink hex code */
        color: white !important;
        border-radius: 20px;
        font-weight: bold;
    }

        .btn-pink:hover {
            background-color: #ec407a !important;
        }

    .border-pink {
        border: 2px solid #fce4ec !important; /* Matched to exact EventEase border pink hex code */
    }

    .text-pink-theme {
        color: #880e4f !important; /* Matched to exact EventEase deep red/burgundy hex code */
    }
</style>

<div class="dashboard-container">
    <div class="text-center mb-5">
        <div class="hello-kitty-float">
            <img src="~/images/hello-kitty.png" alt="Hello Kitty" style="width: 100%;" />
        </div>
        <h1 class="display-4 fw-bold text-pink-theme">GLMS Dashboard</h1>
        <p class="lead text-muted">Manage your logistics, contracts, and shipping profiles with style.</p>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card stat-card p-4 text-center shadow-sm">
                <i class="bi bi-people-fill card-icon"></i>
                <h3 class="mt-3">Clients</h3>
                <p class="text-muted">Manage global shipping profiles</p>
                <a asp-controller="Clients" asp-action="Index" class="btn btn-pink">View All</a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card stat-card p-4 text-center shadow-sm">
                <i class="bi bi-file-earmark-text-fill card-icon"></i>
                <h3 class="mt-3">Contracts</h3>
                <p class="text-muted">Track SLA rules and signed PDFs</p>
                <a asp-controller="Contracts" asp-action="Index" class="btn btn-pink">View All</a>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card stat-card p-4 text-center shadow-sm">
                <i class="bi bi-truck card-icon"></i>
                <h3 class="mt-3">Service Requests</h3>
                <p class="text-muted">Monitor conversions and active jobs</p>
                <a asp-controller="ServiceRequests" asp-action="Index" class="btn btn-pink">Manage</a>
            </div>
        </div>
    </div>

    <div class="mt-5 p-5 text-white rounded shadow-sm" style="background: linear-gradient(45deg, #f06292, #fce4ec); color: #880e4f !important;">
        <h2>Ready to ship?</h2>
        <p>Creating a seamless operational experience for your global clients starts here.</p>
        <a asp-controller="ServiceRequests" asp-action="Create" class="btn btn-outline-light mt-2" style="border-color: #880e4f; color: #880e4f; font-weight: bold;">Create New Service Request</a>
    </div>

    <div class="mt-5 p-4 rounded shadow-sm bg-white border-pink border">
        <h3 class="text-pink-theme"><i class="bi bi-box-seam-fill"></i> System Logistics Overview 🎀</h3>
        <hr class="border-pink" />
        <div class="table-responsive">
            <table class="table table-hover">
                <thead>
                    <tr>
                        <th style="color: #f06292 !important;">Contract Name</th>
                        <th style="color: #f06292 !important;">Start Date</th>
                        <th style="color: #f06292 !important;">End Date</th>
                        <th style="color: #f06292 !important;">Operational Status</th>
                        <th style="color: #f06292 !important;">Target Client</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.ContractName</td>
                                <td>@item.StartDate.ToString("dd MMM yyyy")</td>
                                <td>@item.EndDate.ToString("dd MMM yyyy")</td>
                                <td>
                                    <span class="badge @(item.Status.ToString() == "Active" ? "bg-success" : "bg-warning text-dark")">
                                        @item.Status
                                    </span>
                                </td>
                                <td>@(item.Client?.Name ?? "No Client Linked")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted">No supply chain movements scheduled yet. Time to create some magic! ✨</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>